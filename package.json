{
  "name": "ghostmapper",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "vite build",
    "build:cf": "VITE_WRANGLER_ENV=cf VITE_USER_NODE_ENV=production vite build",
    "build:cf:watch": "bun run build:cf --watch",
    "build:local": "VITE_WRANGLER_ENV=local VITE_USER_NODE_ENV=development vite build",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "db:dump": "sqlite3 $(find .wrangler/state/v3/d1/miniflare-D1DatabaseObject -type f -name '*.sqlite' -print -quit) '.dump' > local_$(date +'%s').sql",
    "db:generate": "drizzle-kit generate --name",
    "db:migrate:local": "wrangler d1 migrations apply ghostmapper-prod --local",
    "db:migrate:cf:prod": "wrangler d1 migrations apply ghostmapper-prod --remote",
    "db:migrate:cf:preview": "wrangler d1 migrations apply --env preview ghostmapper-preview --remote",
    "db:studio:local": "LOCAL_DB_PATH=$(find .wrangler/state/v3/d1/miniflare-D1DatabaseObject -type f -name '*.sqlite' -print -quit) drizzle-kit studio",
    "db:studio:cf:preview": "source .env.drizzle && DB_ID='b7a2dc55-f43b-40f0-993a-abb36a6a5543' drizzle-kit studio",
    "db:studio:cf:prod": "source .env.drizzle && DB_ID='8ff2682b-8e78-4f9e-87bd-47f409d94184' drizzle-kit studio",
    "dev": "mullvad-exclude vite dev",
    "dev:cf": "bunx wrangler pages dev",
    "dev:cf:watch": "bun run dev:cf --live-reload",
    "dev:local": "VITE_WRANGLER_ENV=local VITE_USER_NODE_ENV=development mullvad-exclude vite -d dev",
    "format": "prettier --write .",
    "lint": "prettier --check . && eslint .",
    "prepare": "svelte-kit sync",
    "preview": "vite preview",
    "test:db": "$HOME/.turso/sqld",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:watch": "vitest watch",
    "test:browser": "vitest --workspace=vitest.workspace.ts",
    "i18n:translate": "bunx @inlang/cli machine translate --project project.inlang",
    "i18n:build": "bunx @inlang/paraglide-js compile --project ./project.inlang --outdir ./src/lib/paraglide"
  },
  "testDependencies": {
    "@vitest/browser": "^2.1.5",
    "@vitest/ui": "^2.1.5",
    "jsdom": "^25.0.1",
    "turso": "^0.1.0",
    "vitest": "^2.1.5",
    "vitest-browser-svelte": "^0.0.1",
    "webdriverio": "^9.3.0"
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "^3.0.8",
    "@tanstack/svelte-query-devtools": "^5.75.5",
    "@types/eslint": "^9.6.1",
    "@types/geojson": "^7946.0.16",
    "drizzle-kit": "^0.31.1",
    "eslint": "^9.26.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-svelte": "^3.5.1",
    "globals": "^16.1.0",
    "prettier": "^3.5.3",
    "prettier-plugin-multiline-arrays": "^4.0.3",
    "prettier-plugin-svelte": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "svelte-check": "^4.1.7",
    "typescript-eslint": "^8.32.0",
    "vite-plugin-node-polyfills": "^0.23.0",
    "wrangler": "^4.14.4"
  },
  "type": "module",
  "trustedDependencies": [
    "@sveltejs/kit",
    "edgedriver",
    "esbuild",
    "geckodriver",
    "msw",
    "sharp",
    "svelte-preprocess",
    "workerd"
  ],
  "dependencies": {
    "@auth/core": "^0.39.0",
    "@auth/d1-adapter": "^1.9.0",
    "@auth/drizzle-adapter": "^1.9.0",
    "@auth/sveltekit": "1.7.4",
    "@emeraldpay/hashicon": "^0.5.2",
    "@inlang/paraglide-js": "^2.0.12",
    "@libsql/client": "0.15.4",
    "@mapbox/tilebelt": "^2.0.2",
    "@placemarkio/geo-viewport": "^1.0.2",
    "@steeze-ui/heroicons": "^2.4.2",
    "@steeze-ui/svelte-icon": "^1.6.2",
    "@sveltejs/adapter-cloudflare": "^7.0.3",
    "@sveltejs/kit": "^2.20.8",
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/typography": "^0.5.16",
    "@tanstack/svelte-query": "^5.75.5",
    "@testing-library/svelte": "^5.2.7",
    "@thisux/sveltednd": "0.0.20",
    "@turf/bbox": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "autoprefixer": "^10.4.21",
    "coordinate-parser": "^1.0.7",
    "daisyui": "4.12.24",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.43.1",
    "drizzle-zod": "^0.7.1",
    "maplibre-gl": "^5.5.0",
    "postcss": "^8.5.3",
    "proj4": "^2.15.0",
    "short-uuid": "^5.2.0",
    "svelte": "^5.28.2",
    "svelte-fa": "^4.0.4",
    "svelte-file-dropzone": "^2.0.9",
    "svelte-range-slider-pips": "^3.2.2",
    "sveltekit-flash-message": "^2.4.6",
    "sveltekit-superforms": "^2.25.0",
    "tailwindcss": "3.4.17",
    "tailwindcss-unimportant": "^2.1.1",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "zod": "^3.24.4"
  }
}
