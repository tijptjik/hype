{
  "name": "ghostsigns",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "mullvad-exclude vite dev",
    "dev:cf": "mullvad-exclude bunx wrangler pages dev",
    "dev:sync": "prisma generate && vite build",
    "dev:serve": "mullvad-exclude bunx wrangler pages dev",
    "dev:full": "bun run dev:sync && bun run dev:serve",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "test": "vitest",
    "lint": "prettier --check . && eslint .",
    "format": "prettier --write .",
    "prepare": "svelte-kit sync"
  },
  "devDependencies": {
    "@auth/core": "^0.34.2",
    "@auth/d1-adapter": "^1.4.2",
    "@auth/prisma-adapter": "^2.4.2",
    "@auth/sveltekit": "^1.4.2",
    "@prisma/adapter-d1": "^5.18.0",
    "@prisma/client": "^5.18.0",
    "@sveltejs/adapter-cloudflare": "^4.7.2",
    "@sveltejs/adapter-static": "^3.0.4",
    "@sveltejs/kit": "^2.5.22",
    "@sveltejs/vite-plugin-svelte": "^3.1.1",
    "@tailwindcss/typography": "^0.5.14",
    "@types/eslint": "^9.6.0",
    "autoprefixer": "^10.4.20",
    "daisyui": "^4.12.10",
    "eslint": "^9.9.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-svelte": "^2.43.0",
    "globals": "^15.9.0",
    "postcss": "^8.4.41",
    "prettier": "^3.3.3",
    "prettier-plugin-svelte": "^3.2.6",
    "prisma": "^5.18.0",
    "svelte": "^5.0.0-next.224",
    "svelte-check": "^3.8.5",
    "svelte-fa": "^4.0.2",
    "tailwindcss": "^3.4.10",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.1.0",
    "vite": "^5.4.1",
    "vitest": "^2.0.5"
  },
  "type": "module",
  "trustedDependencies": [
    "svelte-preprocess"
  ]
}
