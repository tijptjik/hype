{
  "name": "ghostsigns",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "mullvad-exclude vite dev",
    "dev:cf": "mullvad-exclude bunx wrangler pages dev",
    "dev:sync": "SVELTE_ADAPTER=cloudflare bunx vite build --watch",
    "dev:serve": "mullvad-exclude bunx wrangler pages dev --live-reload",
    "dev:full": "bun run dev:sync && bun run dev:serve",
    "build": "VITE_USER_NODE_ENV=production SVELTE_ADAPTER=cloudflare vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "test": "vitest",
    "lint": "prettier --check . && eslint .",
    "format": "prettier --write .",
    "prepare": "svelte-kit sync"
  },
  "devDependencies": {
    "@auth/core": "^0.34.2",
    "@auth/d1-adapter": "^1.4.2",
    "@auth/sveltekit": "^1.4.2",
    "@sveltejs/adapter-cloudflare": "^4.7.2",
    "@sveltejs/adapter-static": "^3.0.4",
    "@sveltejs/kit": "^2.5.24",
    "@sveltejs/vite-plugin-svelte": "^4.0.0-next.6",
    "@tailwindcss/typography": "^0.5.14",
    "@testing-library/svelte": "^5.2.1",
    "@types/eslint": "^9.6.0",
    "autoprefixer": "^10.4.20",
    "better-sqlite3": "^11.2.1",
    "bindings": "^1.5.0",
    "daisyui": "^4.12.10",
    "eslint": "^9.9.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-svelte": "^2.43.0",
    "globals": "^15.9.0",
    "kysely": "^0.27.4",
    "kysely-codegen": "^0.15.0",
    "kysely-ctl": "^0.9.0",
    "kysely-d1": "^0.3.0",
    "maplibre-gl": "^4.6.0",
    "node-gyp": "^10.2.0",
    "postcss": "^8.4.41",
    "prettier": "^3.3.3",
    "prettier-plugin-svelte": "^3.2.6",
    "svelte": "^5.0.0-next.235",
    "svelte-check": "^3.8.6",
    "svelte-fa": "^4.0.2",
    "tailwindcss": "^3.4.10",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.2.0",
    "vite": "^5.4.2",
    "vitest": "^2.0.5",
    "wrangler": "^3.72.2"
  },
  "type": "module",
  "trustedDependencies": [
    "@sveltejs/kit",
    "better-sqlite3",
    "esbuild",
    "svelte-preprocess",
    "workerd"
  ]
}
