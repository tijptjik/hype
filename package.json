{
  "name": "hype",
  "version": "0.0.1",
  "private": true,
  "issues": {
    "url": "https://github.com/tijptjik/hype/issues"
  },
  "scripts": {
    "dev": "vite dev",
    "dev:no-mullvad": "mullvad-exclude vite dev",
    "dev:local": "vite -d dev",
    "build": "sync && vite build",
    "build:preview": "vite preview",
    "build:cf:prod": "CLOUDFLARE_ENV=production bun run build --mode production",
    "build:cf:preview": "CLOUDFLARE_ENV=preview bun run build --mode preview",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-check --tsconfig ./tsconfig.json --watch",
    "cs:add": "changeset",
    "cs:version": "changeset version",
    "cs:release": "vite build && changeset publish",
    "db:dump": "sqlite3 $(find .wrangler/state/v3/d1/miniflare-D1DatabaseObject -type f -name '*.sqlite' -print -quit) '.dump' > local_$(date +'%s').sql",
    "db:migration:new": "drizzle-kit generate --name",
    "db:migration:run:local": "wrangler d1 migrations apply hype-db-local",
    "db:migration:run:cf:prod": "wrangler d1 migrations apply hype-db-prod --remote --env production",
    "db:migration:run:cf:preview": "wrangler d1 migrations apply hype-db-preview --remote --env preview",
    "db:studio:local": "drizzle-kit studio --config=drizzle.config.ts",
    "db:studio:cf:prod": "export $(xargs <.env.drizzle.prod.local) && drizzle-kit studio --config=drizzle.config.ts",
    "db:studio:cf:preview": "export $(xargs <.env.drizzle.preview.local) && drizzle-kit studio --config=drizzle.config.ts",
    "deploy:prod": "bun wrangler deploy --name hype-prod --env production",
    "deploy:preview": "bun wrangler deploy --name hype-preview --env preview",
    "lint": "prettier --check . && eslint .",
    "lint:branch": "bunx branch-name-lint .husky/branch-name-lint.json",
    "format": "prettier --write .",
    "prepare": "husky && svelte-kit sync",
    "test": "vitest --config=vitest.config.ts",
    "test:run": "vitest run --config=vitest.config.ts",
    "test:watch": "vitest watch --config=vitest.config.ts",
    "test:ui": "vitest --config=vitest.config.ts --ui",
    "i18n:translate": "bunx @inlang/cli machine translate --project project.inlang",
    "i18n:build": "bunx @inlang/paraglide-js compile --project ./project.inlang --outdir ./src/lib/paraglide",
    "commit": "git-cz"
  },
  "testDependencies": {
    "@vitest/browser": "^2.1.5",
    "@vitest/ui": "^2.1.5",
    "jsdom": "^25.0.1",
    "turso": "^0.1.0",
    "vitest": "^2.1.5",
    "vitest-browser-svelte": "^0.0.1",
    "webdriverio": "^9.3.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.4",
    "@cloudflare/vite-plugin": "^1.6.0",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@commitlint/cz-commitlint": "^19.8.1",
    "@commitlint/prompt-cli": "^19.8.1",
    "@miniflare/d1": "^2.14.4",
    "@nerdfolio/drizzle-d1-helpers": "^0.1.4",
    "@sveltejs/adapter-static": "^3.0.8",
    "@tanstack/svelte-query-devtools": "^5.80.7",
    "@types/eslint": "^9.6.1",
    "@types/geojson": "^7946.0.16",
    "@types/papaparse": "^5.3.16",
    "branch-name-lint": "^3.0.1",
    "commitizen": "^4.3.1",
    "dotenv-load": "^3.0.0",
    "drizzle-kit": "^0.31.1",
    "eslint": "^9.28.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-svelte": "^3.9.2",
    "globals": "^16.2.0",
    "husky": "^9.1.7",
    "inquirer": "^9.3.7",
    "prettier": "^3.5.3",
    "prettier-plugin-multiline-arrays": "^4.0.3",
    "prettier-plugin-svelte": "^3.4.0",
    "prettier-plugin-tailwindcss": "^0.6.12",
    "svelte-check": "^4.2.1",
    "typescript-eslint": "^8.34.0",
    "vite-node": "^3.2.3",
    "vite-plugin-node-polyfills": "^0.23.0",
    "vitest": "^3.2.3",
    "wrangler": "^4.20.0"
  },
  "type": "module",
  "trustedDependencies": [
    "@sveltejs/kit",
    "edgedriver",
    "esbuild",
    "geckodriver",
    "msw",
    "sharp",
    "svelte-preprocess",
    "workerd"
  ],
  "dependencies": {
    "@emeraldpay/hashicon": "^0.5.2",
    "@inlang/paraglide-js": "^2.1.0",
    "@libsql/client": "0.15.8",
    "@mapbox/tilebelt": "^2.0.2",
    "@placemarkio/geo-viewport": "^1.0.2",
    "@steeze-ui/heroicons": "^2.4.2",
    "@steeze-ui/svelte-icon": "^1.6.2",
    "@sveltejs/adapter-cloudflare": "^7.0.4",
    "@sveltejs/kit": "^2.21.5",
    "@sveltejs/vite-plugin-svelte": "^5.1.0",
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/typography": "^0.5.16",
    "@tanstack/svelte-query": "^5.80.7",
    "@testing-library/svelte": "^5.2.8",
    "@thisux/sveltednd": "0.0.20",
    "@turf/bbox": "^7.2.0",
    "@types/proj4": "^2.5.6",
    "@types/uuid": "^10.0.0",
    "autoprefixer": "^10.4.21",
    "better-auth": "^1.2.9",
    "coordinate-parser": "^1.0.7",
    "daisyui": "4.12.24",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.44.2",
    "drizzle-zod": "^0.7.1",
    "maplibre-gl": "^5.6.0",
    "node-gyp": "^11.2.0",
    "papaparse": "^5.5.3",
    "postcss": "^8.5.5",
    "proj4": "^2.17.0",
    "runed": "^0.28.0",
    "short-uuid": "^5.2.0",
    "svelte": "^5.34.1",
    "svelte-fa": "^4.0.4",
    "svelte-file-dropzone": "^2.0.9",
    "svelte-range-slider-pips": "3.2.1",
    "sveltekit-flash-message": "^2.4.6",
    "sveltekit-superforms": "^2.26.1",
    "tailwindcss": "3.4.17",
    "tailwindcss-unimportant": "^2.1.1",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "zod": "3.24.2"
  },
  "config": {
    "commitizen": {
      "path": "@commitlint/cz-commitlint",
      "config": {
        "path": ".cz-config.js"
      }
    }
  }
}