{
  "name": "ghostmapper",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "vite build",
    "build:cf": "VITE_WRANGLER_ENV=cf VITE_USER_NODE_ENV=production vite build",
    "build:cf:watch": "bun run build:cf --watch",
    "build:local": "VITE_WRANGLER_ENV=local VITE_USER_NODE_ENV=development vite build",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "db:dump": "sqlite3 $(find .wrangler/state/v3/d1/miniflare-D1DatabaseObject -type f -name '*.sqlite' -print -quit) '.dump' > local_$(date +'%s').sql",
    "db:generate": "drizzle-kit generate --name",
    "db:migrate:local": "wrangler d1 migrations apply ghostmapper-prod --local",
    "db:migrate:cf:prod": "wrangler d1 migrations apply ghostmapper-prod --remote",
    "db:migrate:cf:preview": "wrangler d1 migrations apply --env preview ghostmapper-preview --remote",
    "db:studio:local": "LOCAL_DB_PATH=$(find .wrangler/state/v3/d1/miniflare-D1DatabaseObject -type f -name '*.sqlite' -print -quit) drizzle-kit studio",
    "db:studio:cf:preview": "source .env.drizzle && DB_ID='b7a2dc55-f43b-40f0-993a-abb36a6a5543' drizzle-kit studio",
    "db:studio:cf:prod": "source .env.drizzle && DB_ID='117e417f-6b38-4b52-a5b5-0320d6944fbe' drizzle-kit studio",
    "dev": "mullvad-exclude vite dev",
    "dev:cf": "bunx wrangler pages dev",
    "dev:cf:watch": "bun run dev:cf --live-reload",
    "dev:local": "VITE_WRANGLER_ENV=local VITE_USER_NODE_ENV=development mullvad-exclude vite -d dev",
    "format": "prettier --write .",
    "lint": "prettier --check . && eslint .",
    "prepare": "svelte-kit sync",
    "preview": "vite preview",
    "test:db": "$HOME/.turso/sqld",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:watch": "vitest watch",
    "test:browser": "vitest --workspace=vitest.workspace.ts"
  },
  "devDependencies": {
    "@steeze-ui/heroicons": "^2.4.0",
    "@sveltejs/adapter-static": "^3.0.6",
    "@types/better-sqlite3": "^7.6.11",
    "@types/eslint": "^9.6.1",
    "@types/geojson": "^7946.0.14",
    "@vitest/browser": "^2.1.5",
    "@vitest/ui": "^2.1.5",
    "drizzle-kit": "^0.28.1",
    "better-sqlite3": "^11.5.0",
    "eslint": "^9.15.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-svelte": "^2.46.0",
    "globals": "^15.12.0",
    "jsdom": "^25.0.1",
    "node-gyp": "^10.2.0",
    "mapbox-gl-arcgis-featureserver": "^0.0.8",
    "playwright": "^1.49.0",
    "prettier": "^3.3.3",
    "prettier-plugin-multiline-arrays": "^3.0.6",
    "prettier-plugin-svelte": "^3.2.8",
    "prettier-plugin-tailwindcss": "^0.6.8",
    "svelte-check": "^4.0.9",
    "typescript-eslint": "^8.15.0",
    "vite-plugin-node-polyfills": "^0.22.0",
    "vitest": "^2.1.5",
    "vitest-browser-svelte": "^0.0.1",
    "webdriverio": "^9.2.14",
    "wrangler": "^3.87.0"
  },
  "type": "module",
  "trustedDependencies": [
    "@sveltejs/kit",
    "better-sqlite3",
    "edgedriver",
    "esbuild",
    "geckodriver",
    "msw",
    "svelte-preprocess",
    "workerd"
  ],
  "dependencies": {
    "@auth/core": "^0.37.4",
    "@auth/d1-adapter": "^1.7.4",
    "@auth/drizzle-adapter": "^1.7.4",
    "@auth/sveltekit": "^1.7.4",
    "@inlang/paraglide-js": "1.11.3",
    "@inlang/paraglide-sveltekit": "^0.11.5",
    "@libsql/client": "v0.15.0-pre.1",
    "@steeze-ui/svelte-icon": "^1.6.0",
    "@sveltejs/adapter-cloudflare": "^4.7.4",
    "@sveltejs/kit": "^2.8.1",
    "@sveltejs/vite-plugin-svelte": "^4.0.1",
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/typography": "^0.5.15",
    "@testing-library/svelte": "^5.2.4",
    "@thisux/sveltednd": "0.0.16",
    "autoprefixer": "^10.4.20",
    "cloudinary": "^2.5.1",
    "daisyui": "^4.12.14",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.36.3",
    "drizzle-zod": "^0.5.1",
    "maplibre-gl": "^4.7.1",
    "postcss": "^8.4.49",
    "short-uuid": "^5.2.0",
    "sql.js": "^1.12.0",
    "svelte": "^5.2.3",
    "svelte-cloudinary": "^2.3.0",
    "svelte-fa": "^4.0.3",
    "svelte-file-dropzone": "^2.0.9",
    "sveltekit-superforms": "^2.20.1",
    "tailwindcss": "^3.4.15",
    "tailwindcss-unimportant": "^2.1.1",
    "turso": "^0.1.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "zod": "^3.23.8"
  }
}
