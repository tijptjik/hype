{
  "name": "ghostmapper",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "vite build",
    "build:cf": "VITE_WRANGLER_ENV=cf VITE_USER_NODE_ENV=production vite build",
    "build:cf:watch": "bun run build:cf --watch",
    "build:local": "VITE_WRANGLER_ENV=local VITE_USER_NODE_ENV=development vite build",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "db:dump": "sqlite3 $(find .wrangler/state/v3/d1/miniflare-D1DatabaseObject -type f -name '*.sqlite' -print -quit) '.dump' > local_$(date +'%s').sql",
    "db:generate": "drizzle-kit generate --name",
    "db:migrate:local": "wrangler d1 migrations apply ghostmapper-prod --local",
    "db:migrate:cf:prod": "wrangler d1 migrations apply ghostmapper-prod --remote",
    "db:migrate:cf:preview": "wrangler d1 migrations apply --env preview ghostmapper-preview --remote",
    "db:studio:local": "LOCAL_DB_PATH=$(find .wrangler/state/v3/d1/miniflare-D1DatabaseObject -type f -name '*.sqlite' -print -quit) drizzle-kit studio",
    "db:studio:cf:preview": "source .env.drizzle && DB_ID='b7a2dc55-f43b-40f0-993a-abb36a6a5543' drizzle-kit studio",
    "db:studio:cf:prod": "source .env.drizzle && DB_ID='117e417f-6b38-4b52-a5b5-0320d6944fbe' drizzle-kit studio",
    "dev": "mullvad-exclude vite dev",
    "dev:cf": "bunx wrangler pages dev",
    "dev:cf:watch": "bun run dev:cf --live-reload",
    "dev:local": "VITE_WRANGLER_ENV=local VITE_USER_NODE_ENV=development mullvad-exclude vite -d dev",
    "format": "prettier --write .",
    "lint": "prettier --check . && eslint .",
    "prepare": "svelte-kit sync",
    "preview": "vite preview",
    "test": "vitest",
    "test:browser": "vitest"
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "^3.0.5",
    "@testing-library/svelte": "^5.2.1",
    "@types/eslint": "^9.6.1",
    "@types/geojson": "^7946.0.14",
    "@vitest/browser": "^2.1.1",
    "drizzle-kit": "^0.24.2",
    "eslint": "^9.11.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-svelte": "^2.44.0",
    "globals": "^15.9.0",
    "jsdom": "^25.0.1",
    "mapbox-gl-arcgis-featureserver": "^0.0.8",
    "playwright": "^1.47.2",
    "prettier": "^3.3.3",
    "prettier-plugin-svelte": "^3.2.6",
    "prettier-plugin-tailwindcss": "^0.6.8",
    "svelte-check": "^3.8.6",
    "typescript-eslint": "^8.7.0",
    "vitest": "^2.1.1",
    "vitest-browser-svelte": "^0.0.1",
    "webdriverio": "^9.1.0",
    "wrangler": "^3.78.8"
  },
  "type": "module",
  "trustedDependencies": [
    "@sveltejs/kit",
    "better-sqlite3",
    "esbuild",
    "svelte-preprocess",
    "workerd"
  ],
  "dependencies": {
    "@auth/core": "^0.34.2",
    "@auth/d1-adapter": "^1.5.0",
    "@auth/drizzle-adapter": "^1.5.0",
    "@auth/sveltekit": "^1.5.0",
    "@inlang/paraglide-js": "1.11.2",
    "@inlang/paraglide-sveltekit": "^0.11.0",
    "@libsql/client": "^0.9.0",
    "@sveltejs/adapter-cloudflare": "^4.7.2",
    "@sveltejs/kit": "^2.5.28",
    "@sveltejs/vite-plugin-svelte": "^4.0.0-next.7",
    "@tailwindcss/typography": "^0.5.15",
    "autoprefixer": "^10.4.20",
    "daisyui": "^4.12.10",
    "drizzle-orm": "^0.33.0",
    "drizzle-zod": "^0.5.1",
    "maplibre-gl": "^4.7.1",
    "postcss": "^8.4.47",
    "short-uuid": "^5.2.0",
    "svelte": "^5.0.0-next.259",
    "svelte-fa": "^4.0.3",
    "sveltekit-superforms": "^2.19.0",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.2",
    "vite": "^5.4.7",
    "zod": "^3.23.8"
  }
}
