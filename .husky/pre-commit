# Check if we're trying to create a merge commit
if [ -f "$(git rev-parse --git-dir)/MERGE_HEAD" ]; then
    echo "Merge commits are not allowed. Please use rebase instead."
    exit 1
fi

# Get list of staged files before formatting
STAGED_FILES=$(git diff --cached --name-only)

if [ -n "$STAGED_FILES" ]; then
    echo "🎨 Running prettier to format files..."
    
    # Run formatter on all files
    bun run format
    
    # Check if any staged files were modified by formatting
    MODIFIED_STAGED_FILES=""
    echo "$STAGED_FILES" | while read -r file; do
        if [ -f "$file" ] && git diff --name-only | grep -q "^$file$"; then
            if [ -z "$MODIFIED_STAGED_FILES" ]; then
                MODIFIED_STAGED_FILES="$file"
            else
                MODIFIED_STAGED_FILES="$MODIFIED_STAGED_FILES\n$file"
            fi
        fi
    done
    
    # If any staged files were modified, exit with instructions
    if git diff --name-only | grep -qF -f <(echo "$STAGED_FILES"); then
        echo ""
        echo "❌ Prettier modified some of your staged files:"
        git diff --name-only | grep -F -f <(echo "$STAGED_FILES") | sed 's/^/  - /'
        echo ""
        echo "📝 Please review the changes and re-stage the files:"
        echo "   git add <files>    # Re-stage the files you want to commit"
        echo "   git commit         # Try committing again"
        echo ""
        echo "💡 Or to stage all formatting changes:"
        echo "   git add .          # Stage all changes including formatting"
        echo "   git commit         # Try committing again"
        exit 1
    fi
fi

echo "✅ Pre-commit checks passed!" 