# Check if we're trying to create a merge commit
if [ -f "$(git rev-parse --git-dir)/MERGE_HEAD" ]; then
    echo "Merge commits are not allowed. Please use rebase instead."
    exit 1
fi

# Get list of staged files before formatting
STAGED_FILES=$(git diff --cached --name-only)

if [ -n "$STAGED_FILES" ]; then
    echo "🎨 Running prettier to format staged files..."
    
    # Run formatter on all files
    bun run format
    
    # Re-stage only the files that were originally staged and got modified
    echo "$STAGED_FILES" | while read -r file; do
        if [ -f "$file" ] && git diff --name-only | grep -q "^$file$"; then
            echo "📝 Re-staging formatted file: $file"
            git add "$file"
        fi
    done
fi

echo "✅ Pre-commit checks passed!" 